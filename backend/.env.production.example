# Production only — copy to .env.production on the server (never commit .env.production).
# Used by: docker compose -f docker-compose.prod.yml
#
# Google OAuth: use a Web client with ONLY production URIs, or add these to your client:
#   Authorized JavaScript origins: https://drpinfotech.com
#   Authorized redirect URIs: https://drpinfotech.com/api/auth/google/callback

SERVER_HOST=0.0.0.0
SERVER_PORT=8003
DEBUG=False

BACKEND_URL=https://drpinfotech.com
FRONTEND_URL=https://drpinfotech.com
CORS_ORIGINS=https://drpinfotech.com

SECRET_KEY=
DATABASE_PATH=database.db

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://drpinfotech.com/api/auth/google/callback

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LOG_LEVEL=INFO

SMTP_SERVER=smtp.gmail.com
USERNAME_EMAIL=
PASSWORD_EMAIL=
EMAIL_FROM=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
