# Production only — copy to .env.production on the server (never commit .env.production).
# Used by: docker compose -f docker-compose.prod.yml
#
# Google OAuth — Web application client. Values must match Google Cloud Console *exactly* (no trailing slash on redirect URI path beyond below).
#   Authorized JavaScript origins: https://drpinfotech.com
#   Authorized redirect URIs: https://drpinfotech.com/api/auth/google/callback
# If you use www, set BACKEND_URL/GOOGLE_REDIRECT_URI to https://www.drpinfotech.com and register those same URLs with www in Console.
# Error 400 redirect_uri_mismatch = Console URI ≠ the string the app sends (check backend logs: "Google OAuth redirect_uri:").
#
# Zerodha Kite Connect — Redirect URL (Kite developer console) must match Flask /callback:
#   Production (TLS on 443, same host as BACKEND_URL): https://drpinfotech.com/callback
#   Docker on EC2: browsers hit Nginx :5175; nginx proxies /callback to backend:8003 (see frontend/nginx.conf).
#   Local direct API: http://localhost:8003/callback

SERVER_HOST=0.0.0.0
SERVER_PORT=8003
DEBUG=False

BACKEND_URL=https://drpinfotech.com
FRONTEND_URL=https://drpinfotech.com
CORS_ORIGINS=https://drpinfotech.com

SECRET_KEY=
DATABASE_PATH=database.db

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://drpinfotech.com/api/auth/google/callback

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LOG_LEVEL=INFO

SMTP_SERVER=smtp.gmail.com
USERNAME_EMAIL=
PASSWORD_EMAIL=
EMAIL_FROM=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
